{
  "name": "hallucinet-explorer",
  "version": "0.1.0",
  "description": "AI-hallucinated web browser — every page is generated by an LLM",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc && cp src/renderer/chrome.html dist/renderer/chrome.html && cp src/renderer/chrome.css dist/renderer/chrome.css",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": ["electron", "llm", "browser"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "electron": "^40.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3"
  }
}
